# Copiar para .env.local (ou .env) e preencher com o Neon Console.
# Nunca commitar ficheiros com passwords.

# Neon — Pooled connection (app / Prisma Client em runtime)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# Neon — Direct connection (Prisma Migrate; host sem "-pooler")
# Opcional: descomentar em prisma/schema.prisma → directUrl = env("DIRECT_URL")
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxxx.REGION.aws.neon.tech/neondb?sslmode=require"
