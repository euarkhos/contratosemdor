// Schema v0 — Contrato sem Dor (Prisma + Neon)
// Migrações: prisma migrate dev
// Auth.js: https://authjs.dev/getting-started/adapters/prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Opcional: descomentar e definir DIRECT_URL no .env se `migrate` falhar com pooler Neon
  // directUrl = env("DIRECT_URL")
}

// --- Auth.js (adapter Prisma) — manter campos exigidos pelo adapter ---

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?

  accounts Account[]
  sessions Session[]

  clientProfile  ClientProfile?
  studentProfile StudentProfile?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// --- Domínio: perfis ---

model ClientProfile {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  displayName     String?  @map("display_name")
  documentTaxId   String?  @map("document_tax_id")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  contracts Contract[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("client_profiles")
}

model StudentProfile {
  id                      String    @id @default(uuid())
  userId                  String    @unique @map("user_id")
  courseSemester          Int       @map("course_semester")
  levelCode               String    @map("level_code") // N1 | N2 | N3
  completedAnalysesCount  Int       @default(0) @map("completed_analyses_count")
  scoreTier               Int       @default(1) @map("score_tier") // 1 | 2 | 3
  programTier             String    @default("STUDENT") @map("program_tier")
  avgClientRating         Decimal?  @map("avg_client_rating") @db.Decimal(5, 2)
  avgAnalysisTimeMinutes  Decimal?  @map("avg_analysis_time_minutes") @db.Decimal(8, 2)
  tutorialCompletedAt     DateTime? @map("tutorial_completed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("student_profiles")
}

// --- Contratos (núcleo v0) ---

model ContractType {
  id                   String   @id @default(uuid())
  slug                 String   @unique
  label                String
  baseComplexityWeight Decimal? @map("base_complexity_weight") @db.Decimal(8, 4)

  contracts Contract[]

  @@map("contract_types")
}

model Contract {
  id               String   @id @default(uuid())
  clientProfileId  String   @map("client_profile_id")
  contractTypeId   String   @map("contract_type_id")
  status           String

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Restrict)
  contractType  ContractType  @relation(fields: [contractTypeId], references: [id], onDelete: Restrict)

  documents   ContractDocument[]
  preAnalysis PreAnalysis?
  payments    Payment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clientProfileId])
  @@index([status])
  @@map("contracts")
}

model ContractDocument {
  id          String @id @default(uuid())
  contractId  String @map("contract_id")
  storageKey  String @map("storage_key")
  mimeType    String @map("mime_type")
  version     Int    @default(1)

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([contractId])
  @@map("contract_documents")
}

model PreAnalysis {
  id                    String   @id @default(uuid())
  contractId            String   @unique @map("contract_id")
  complexityTier        String   @map("complexity_tier") // low | medium | high
  complexityScore       Decimal? @map("complexity_score") @db.Decimal(8, 4)
  quotedPriceBrl        Decimal  @map("quoted_price_brl") @db.Decimal(12, 2)
  bundleDiscountPercent Decimal? @map("bundle_discount_percent") @db.Decimal(5, 2)
  iaModelVersion        String?  @map("ia_model_version")

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("pre_analyses")
}

model Payment {
  id           String    @id @default(uuid())
  contractId   String    @map("contract_id")
  purpose      String
  amountBrl    Decimal   @map("amount_brl") @db.Decimal(12, 2)
  gatewayFeeBrl Decimal? @map("gateway_fee_brl") @db.Decimal(12, 2)
  method       String    @default("pix")
  status       String
  externalRef  String?   @map("external_ref")
  paidAt       DateTime? @map("paid_at")

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([contractId])
  @@index([status])
  @@map("payments")
}
